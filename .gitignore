.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
.packages

# Build outputs — the biggest weight savings
/build/
**/build/
/coverage/

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# ============================================================
# PUBSPEC LOCK (optional: remove this line if you want
# reproducible installs on CI — keep it for libraries,
# omit it for apps. For a Flutter app, locking is recommended
# so leave pubspec.lock tracked)
# pubspec.lock

